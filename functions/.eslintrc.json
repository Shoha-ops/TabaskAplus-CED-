{
  "root": true,
  "env": {
    "es6": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2018
  },
  "extends": [
    "eslint:recommended",
    "google"
  ],
  "rules": {
    "quotes": ["error", "double"],
    "indent": ["error", 4],
    "object-curly-spacing": "off",
    "comma-dangle": "off",
    "max-len": ["error", { "code": 120 }],
    "linebreak-style": "off"
  }
}
